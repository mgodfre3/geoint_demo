# ============================================================
# GEOINT Demo — Video Indexer Dedicated Cluster Environment
# ============================================================
# Deploys Video Indexer to a dedicated AKS Arc cluster with GPU.
# This cluster runs ONLY Demo 5 (Video Indexer), separate from
# the main GEOINT demo cluster.
#
# Deploy with:
#   .\demo5-video-indexer\scripts\deploy-vi-cluster.ps1 -EnvFile .env.template.mobile-vi
#
# ============================================================

# --- Azure Subscription & Resource Group ---
AZURE_SUBSCRIPTION_ID=fbaf508b-cb61-4383-9cda-a42bfa0c7bc9
AZURE_RESOURCE_GROUP=acx-geoint-mobile
AZURE_LOCATION=eastus

# --- Azure Local Infrastructure ---
AZURE_CUSTOM_LOCATION_ID=/subscriptions/fbaf508b-cb61-4383-9cda-a42bfa0c7bc9/resourcegroups/acx-mobile-azl/providers/microsoft.extendedlocation/customlocations/mobile
AZURE_LOGICAL_NETWORK_ID=/subscriptions/fbaf508b-cb61-4383-9cda-a42bfa0c7bc9/resourceGroups/acx-mobile-azl/providers/Microsoft.AzureStackHCI/logicalNetworks/mobile-Lnet-vlan50

# --- Dedicated VI AKS Arc Cluster ---
VI_AKS_CLUSTER_NAME=mobile-vi
VI_AKS_KUBERNETES_VERSION=1.32.9

# GPU node pool — for DeepStream AI inference
VI_GPU_NODE_VM_SIZE=Standard_NC8_A2
VI_GPU_NODE_COUNT=1

# CPU node pool — for indexing, MSSQL, RabbitMQ, webapi (needs >=16 CPU)
VI_CPU_NODE_VM_SIZE=Standard_D16s_v3
VI_CPU_NODE_COUNT=1

# --- Video Indexer Account ---
VI_ACCOUNT_NAME=AC-VI
VI_ACCOUNT_RESOURCE_GROUP=acx-geoint-mobile
VI_ACCOUNT_ID=d987d021-dd25-4fec-80af-09631f7c7726
VI_EXTENSION_NAME=video-indexer
VI_ENDPOINT_URI=https://mobile-vi.adaptivecloudlab.com
VI_RELEASE_NAMESPACE=default
VI_STORAGE_CLASS=longhorn
VI_GPU_TOLERATION_KEY=nvidia.com/gpu
VI_EXTENSION_VERSION=

# --- Camera ---
CAMERA_NAME=geoint-booth-cam
CAMERA_RTSP_URL=rtsp://root:p%40ssw0rd@172.25.10.13/axis-media/media.amp?camera=1
